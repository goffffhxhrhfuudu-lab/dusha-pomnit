<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Душа помнит — Мила Вайс</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,400&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --pearl:#F7F8F9;
    --pearl-deep:#EEF0F2;
    --fog:#E6E9EB;
    --platinum:#C7CDD1;
    --ink:#1F232A;
    --ink-soft:#5B6168;
    --ink-faint:#8A9097;
    --accent:#74909E;
    --accent-deep:#42606D;
    --line:#D8DCDE;
    --white:#FFFFFF;
    --radius:18px;
    --radius-sm:10px;
    --maxw:1140px;
    --serif:'Fraunces', serif;
    --sans:'Manrope', sans-serif;
  }

  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    font-family:var(--sans);
    color:var(--ink);
    background:var(--pearl);
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  img,svg{display:block;max-width:100%;}
  a{color:inherit;text-decoration:none;}
  button{font-family:inherit;border:none;background:none;cursor:pointer;}
  ul{list-style:none;}

  :focus-visible{outline:2px solid var(--accent-deep);outline-offset:3px;}

  .container{max-width:var(--maxw);margin:0 auto;padding:0 28px;}

  .eyebrow{
    display:flex;align-items:center;gap:10px;
    font-size:13px;letter-spacing:.14em;text-transform:uppercase;
    color:var(--accent-deep);font-weight:600;margin-bottom:18px;
  }
  .facet{width:1em;height:1em;color:var(--accent);flex-shrink:0;}

  .section-title{
    font-family:var(--serif);
    font-weight:400;
    font-size:clamp(28px,4vw,42px);
    line-height:1.2;
    max-width:680px;
    margin-bottom:20px;
  }
  .section-lede{
    color:var(--ink-soft);
    font-size:17px;
    max-width:560px;
    margin-bottom:46px;
  }

  .reveal{opacity:0;transform:translateY(18px);transition:opacity .7s ease, transform .7s ease;}
  .reveal.is-visible{opacity:1;transform:translateY(0);}

  /* ---------- NAV ---------- */
  .nav{
    position:sticky;top:0;z-index:50;
    background:rgba(247,248,249,.86);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  .nav__inner{
    display:flex;align-items:center;justify-content:space-between;
    padding:18px 28px;max-width:var(--maxw);margin:0 auto;
  }
  .nav__mark{font-family:var(--serif);font-size:19px;letter-spacing:.01em;}
  .nav__links{display:flex;gap:32px;font-size:14px;color:var(--ink-soft);}
  .nav__links a:hover{color:var(--ink);}
  .nav__cta{
    font-size:14px;font-weight:600;padding:10px 20px;
    border:1px solid var(--ink);border-radius:30px;
    transition:background .2s,color .2s;
  }
  .nav__cta:hover{background:var(--ink);color:var(--pearl);}
  @media (max-width:760px){ .nav__links{display:none;} }

  /* ---------- HERO ---------- */
  .hero{
    position:relative;overflow:hidden;
    padding:96px 0 110px;
    background:radial-gradient(ellipse 80% 60% at 70% 0%, var(--pearl-deep), var(--pearl) 70%);
  }
  .hero__blob{
    position:absolute;border-radius:50%;
    background:radial-gradient(circle, var(--fog), transparent 70%);
    filter:blur(6px);
    animation:drift 22s ease-in-out infinite;
  }
  .hero__blob--a{width:520px;height:520px;top:-220px;right:-160px;}
  .hero__blob--b{width:380px;height:380px;bottom:-200px;left:-120px;animation-delay:-9s;}
  @keyframes drift{
    0%,100%{transform:translate(0,0) scale(1);}
    50%{transform:translate(-26px,22px) scale(1.06);}
  }
  .facet--hero{
    position:absolute;top:-40px;right:-60px;
    width:480px;height:480px;color:var(--platinum);opacity:.55;
    animation:spin 140s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg);}}

  .hero__inner{position:relative;z-index:2;max-width:620px;}
  .hero h1{
    font-family:var(--serif);
    font-weight:400;
    font-size:clamp(36px,5.6vw,58px);
    line-height:1.12;
    margin-bottom:24px;
  }
  .hero h1 em{font-style:italic;color:var(--accent-deep);}
  .hero p{
    font-size:18px;color:var(--ink-soft);max-width:480px;margin-bottom:40px;
  }
  .hero__ctas{display:flex;gap:18px;flex-wrap:wrap;align-items:center;}
  .btn{
    display:inline-flex;align-items:center;justify-content:center;
    padding:15px 30px;border-radius:30px;font-size:15px;font-weight:600;
    transition:transform .2s ease, box-shadow .2s ease, background .2s, color .2s;
  }
  .btn--primary{background:var(--ink);color:var(--pearl);}
  .btn--primary:hover{transform:translateY(-2px);box-shadow:0 14px 28px -16px rgba(0,0,0,.4);}
  .btn--ghost{color:var(--ink);border-bottom:1px solid var(--ink-faint);border-radius:0;padding:15px 2px;}
  .btn--ghost:hover{border-color:var(--ink);}

  /* ---------- ABOUT ---------- */
  .about{padding:110px 0;}
  .about__grid{display:grid;grid-template-columns:220px 1fr;gap:64px;align-items:start;}
  .about__mark{
    width:180px;height:180px;border-radius:50%;
    background:var(--pearl-deep);
    display:flex;align-items:center;justify-content:center;
    color:var(--accent);font-family:var(--serif);font-size:15px;letter-spacing:.06em;
    border:1px solid var(--line);text-align:center;line-height:1.4;
  }
  .about__body p{color:var(--ink-soft);font-size:17px;margin-bottom:18px;max-width:600px;}
  .about__tags{display:flex;gap:10px;flex-wrap:wrap;margin-top:22px;}
  .tag{
    font-size:13px;padding:8px 16px;border-radius:30px;
    border:1px solid var(--line);color:var(--accent-deep);font-weight:600;
  }
  @media (max-width:760px){
    .about__grid{grid-template-columns:1fr;}
    .about__mark{width:120px;height:120px;font-size:13px;}
  }

  /* ---------- RESONANCE ---------- */
  .resonance{padding:90px 0;background:var(--pearl-deep);}
  .resonance__list{
    display:grid;grid-template-columns:1fr 1fr;gap:22px 40px;
  }
  .resonance__item{
    display:flex;gap:14px;align-items:flex-start;
    padding:20px 0;border-top:1px solid var(--line);
    font-size:16px;color:var(--ink);
  }
  .resonance__item .facet{margin-top:5px;}
  @media (max-width:760px){ .resonance__list{grid-template-columns:1fr;} }

  /* ---------- SERVICES ---------- */
  .services{padding:110px 0;}
  .services__grid{
    display:grid;grid-template-columns:repeat(3,1fr);gap:24px;
  }
  .service-card{
    border:1px solid var(--line);border-radius:var(--radius);
    padding:30px 26px;background:var(--white);
    display:flex;flex-direction:column;gap:14px;
    transition:transform .25s ease, box-shadow .25s ease, border-color .25s;
  }
  .service-card:hover{
    transform:translateY(-4px);
    box-shadow:0 24px 40px -28px rgba(20,30,35,.28);
    border-color:var(--accent);
  }
  .service-card h3{font-family:var(--serif);font-weight:400;font-size:22px;}
  .service-card p{color:var(--ink-soft);font-size:15px;flex-grow:1;}
  .service-card__price{
    font-size:14px;font-weight:600;color:var(--accent-deep);
    padding-top:14px;border-top:1px solid var(--line);
    display:flex;justify-content:space-between;align-items:center;
  }
  .service-card__price .placeholder{font-weight:400;font-style:italic;color:var(--ink-faint);}
  @media (max-width:900px){ .services__grid{grid-template-columns:1fr 1fr;} }
  @media (max-width:600px){ .services__grid{grid-template-columns:1fr;} }

  /* ---------- QUIZ ---------- */
  .quiz{padding:110px 0;background:var(--pearl-deep);}
  .quiz__card{
    max-width:640px;margin:0 auto;
    background:var(--white);border:1px solid var(--line);border-radius:var(--radius);
    padding:44px;
  }
  .quiz__progress{display:flex;gap:8px;margin-bottom:30px;}
  .quiz__progress span{
    height:3px;flex:1;background:var(--line);border-radius:2px;overflow:hidden;
  }
  .quiz__progress span i{
    display:block;height:100%;width:0;background:var(--accent-deep);
    transition:width .4s ease;
  }
  .quiz__step{font-size:13px;color:var(--ink-faint);margin-bottom:10px;letter-spacing:.06em;text-transform:uppercase;}
  .quiz__question{font-family:var(--serif);font-size:24px;margin-bottom:26px;}
  .quiz__options{display:flex;flex-direction:column;gap:10px;}
  .quiz__option{
    text-align:left;padding:16px 18px;border:1px solid var(--line);border-radius:var(--radius-sm);
    font-size:15px;transition:border-color .2s, background .2s;
  }
  .quiz__option:hover{border-color:var(--accent);background:var(--pearl);}
  .quiz__result{display:none;text-align:center;}
  .quiz__result.is-active{display:block;}
  .quiz__form.is-hidden{display:none;}
  .quiz__result-label{font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:var(--accent-deep);font-weight:600;margin-bottom:10px;}
  .quiz__result h3{font-family:var(--serif);font-size:30px;margin-bottom:16px;}
  .quiz__result p{color:var(--ink-soft);font-size:16px;max-width:460px;margin:0 auto 30px;}
  .quiz__restart{font-size:13px;color:var(--ink-faint);margin-top:18px;display:inline-block;border-bottom:1px solid var(--ink-faint);}

  /* ---------- TESTIMONIALS ---------- */
  .testimonials{padding:110px 0;}
  .testimonials__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
  .testimonial{
    border:1px dashed var(--platinum);border-radius:var(--radius);
    padding:28px;color:var(--ink-faint);font-style:italic;font-size:15px;
    display:flex;flex-direction:column;gap:18px;justify-content:space-between;min-height:160px;
  }
  .testimonial span{font-style:normal;font-size:13px;color:var(--ink-faint);}
  @media (max-width:900px){ .testimonials__grid{grid-template-columns:1fr;} }

  /* ---------- FINAL CTA ---------- */
  .final-cta{
    padding:120px 0;text-align:center;background:var(--ink);color:var(--pearl);
    position:relative;overflow:hidden;
  }
  .final-cta .facet{color:var(--platinum);opacity:.35;width:340px;height:340px;position:absolute;left:50%;top:-90px;transform:translateX(-50%);}
  .final-cta__inner{position:relative;z-index:2;}
  .final-cta h2{font-family:var(--serif);font-weight:400;font-size:clamp(28px,4vw,40px);margin-bottom:18px;}
  .final-cta p{color:#B8C0C5;margin-bottom:34px;}
  .final-cta .btn--primary{background:var(--pearl);color:var(--ink);}

  footer{padding:36px 0;text-align:center;font-size:13px;color:var(--ink-faint);}

  @media (prefers-reduced-motion:reduce){
    *{animation:none !important;transition:none !important;}
  }
</style>
</head>
<body>

<svg style="display:none" aria-hidden="true">
  <symbol id="facet-icon" viewBox="0 0 100 100">
    <polygon points="50,10 84.64,30 84.64,70 50,90 15.36,70 15.36,30" fill="none" stroke="currentColor" stroke-width="1.4"/>
    <polygon points="50,32 65.6,41 65.6,59 50,68 34.4,59 34.4,41" fill="none" stroke="currentColor" stroke-width="1"/>
    <line x1="50" y1="10" x2="50" y2="32" stroke="currentColor" stroke-width="1"/>
    <line x1="84.64" y1="30" x2="65.6" y2="41" stroke="currentColor" stroke-width="1"/>
    <line x1="84.64" y1="70" x2="65.6" y2="59" stroke="currentColor" stroke-width="1"/>
    <line x1="50" y1="90" x2="50" y2="68" stroke="currentColor" stroke-width="1"/>
    <line x1="15.36" y1="70" x2="34.4" y2="59" stroke="currentColor" stroke-width="1"/>
    <line x1="15.36" y1="30" x2="34.4" y2="41" stroke="currentColor" stroke-width="1"/>
  </symbol>
</svg>

<header class="nav">
  <div class="nav__inner">
    <div class="nav__mark">Душа помнит</div>
    <nav class="nav__links">
      <a href="#about">О Миле</a>
      <a href="#services">Услуги</a>
      <a href="#quiz">Тест</a>
      <a href="#testimonials">Отзывы</a>
    </nav>
    <a href="#contact" class="nav__cta">Записаться</a>
  </div>
</header>

<main>

  <section class="hero" id="top">
    <div class="hero__blob hero__blob--a"></div>
    <div class="hero__blob hero__blob--b"></div>
    <svg class="facet facet--hero" aria-hidden="true"><use href="#facet-icon"/></svg>
    <div class="container">
      <div class="hero__inner">
        <div class="eyebrow"><svg class="facet"><use href="#facet-icon"/></svg>Психология · Регрессии · Система Акаша</div>
        <h1>Душа помнит то, что разум решил <em>забыть</em></h1>
        <p>Мила Вайс — психолог и регрессолог. Помогает увидеть то, что держит тебя на месте, и аккуратно вернуть себе целостность.</p>
        <div class="hero__ctas">
          <a href="#quiz" class="btn btn--primary">Пройти тест → узнать, что нужно сейчас</a>
          <a href="#contact" class="btn btn--ghost">Записаться напрямую</a>
        </div>
      </div>
    </div>
  </section>

  <section class="about reveal" id="about">
    <div class="container">
      <div class="about__grid">
        <div class="about__mark">МВ<br>Мила<br>Вайс</div>
        <div class="about__body">
          <div class="eyebrow"><svg class="facet"><use href="#facet-icon"/></svg>О Миле</div>
          <h2 class="section-title">Структура, а не предсказание</h2>
          <p>Каждая встреча — это не шоу и не предсказание. Это работа: с психикой, с телом, с тем, что накопилось за годы — а иногда раньше, чем началась эта жизнь.</p>
          <p>Я соединяю психологию и более глубокие практики — регрессии и систему Акаша — так, чтобы за результатом стояла структура, а не вера на слово.</p>
          <div class="about__tags">
            <span class="tag">Психолог</span>
            <span class="tag">Регрессолог</span>
            <span class="tag">Тренер системы Акаша</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="resonance reveal" id="resonance">
    <div class="container">
      <div class="eyebrow"><svg class="facet"><use href="#facet-icon"/></svg>Это про тебя?</div>
      <h2 class="section-title">Тебе сюда, если...</h2>
      <ul class="resonance__list">
        <li class="resonance__item"><svg class="facet"><use href="#facet-icon"/></svg>Чувствуешь, что застрял(а) в одной и той же ситуации снова и снова</li>
        <li class="resonance__item"><svg class="facet"><use href="#facet-icon"/></svg>Тревога есть, а внятную причину объяснить не можешь</li>
        <li class="resonance__item"><svg class="facet"><use href="#facet-icon"/></svg>Хочешь понять, откуда в тебе этот страх или паттерн</li>
        <li class="resonance__item"><svg class="facet"><use href="#facet-icon"/></svg>Готов(а) на серьёзную внутреннюю работу, а не разовый совет</li>
        <li class="resonance__item"><svg class="facet"><use href="#facet-icon"/></svg>Ищешь ответы на вопросы о своём пути и предназначении</li>
        <li class="resonance__item"><svg class="facet"><use href="#facet-icon"/></svg>Не знаешь, с чего начать — и это тоже нормальная точка входа</li>
      </ul>
    </div>
  </section>

  <section class="services reveal" id="services">
    <div class="container">
      <div class="eyebrow"><svg class="facet"><use href="#facet-icon"/></svg>Форматы работы</div>
      <h2 class="section-title">Пять путей к одному результату</h2>
      <p class="section-lede">Если не уверен(а), что подходит именно тебе — пройди тест ниже, он подскажет.</p>
      <div class="services__grid">
        <div class="service-card">
          <h3>Диагностика (БДК)</h3>
          <p>Точечная диагностика: что в действительности управляет твоим состоянием прямо сейчас.</p>
          <div class="service-card__price"><span class="placeholder">цену уточнить</span><a href="#quiz">Подробнее →</a></div>
        </div>
        <div class="service-card">
          <h3>Консультация</h3>
          <p>Личная встреча с психологом. Ясность и понятный план действий уже после одной сессии.</p>
          <div class="service-card__price"><span>5 000 ₽</span><a href="#quiz">Подробнее →</a></div>
        </div>
        <div class="service-card">
          <h3>Регрессии</h3>
          <p>Возврат к корню — туда, где сформировался паттерн, который держит тебя сейчас.</p>
          <div class="service-card__price"><span class="placeholder">цену уточнить</span><a href="#quiz">Подробнее →</a></div>
        </div>
        <div class="service-card">
          <h3>Наставничество</h3>
          <p>Сопровождение на дистанции — для тех, кто готов идти глубже одной встречи.</p>
          <div class="service-card__price"><span class="placeholder">цену уточнить</span><a href="#quiz">Подробнее →</a></div>
        </div>
        <div class="service-card">
          <h3>Система Акаша</h3>
          <p>Обучение работе с Акаша-хрониками — для тех, кто хочет не получать ответы, а находить их сам(а).</p>
          <div class="service-card__price"><span class="placeholder">цену уточнить</span><a href="#quiz">Подробнее →</a></div>
        </div>
      </div>
    </div>
  </section>

  <section class="quiz reveal" id="quiz">
    <div class="container">
      <div class="eyebrow"><svg class="facet"><use href="#facet-icon"/></svg>Тест · 3 вопроса · 2 минуты</div>
      <h2 class="section-title">Не уверен(а), что выбрать?</h2>
      <p class="section-lede">Ответь на три вопроса — и узнай, какой формат работы подойдёт именно тебе.</p>

      <div class="quiz__card">
        <div class="quiz__progress">
          <span><i id="bar1"></i></span>
          <span><i id="bar2"></i></span>
          <span><i id="bar3"></i></span>
        </div>

        <form class="quiz__form" id="quizForm">
          <div class="quiz__step" id="quizStep">Вопрос 1 из 3</div>
          <div class="quiz__question" id="quizQuestion"></div>
          <div class="quiz__options" id="quizOptions"></div>
        </form>

        <div class="quiz__result" id="quizResult">
          <div class="quiz__result-label">Тебе подходит</div>
          <h3 id="resultTitle"></h3>
          <p id="resultText"></p>
          <a href="#contact" class="btn btn--primary" id="resultCta">Записаться</a>
          <br>
          <button type="button" class="quiz__restart" id="quizRestart">Пройти тест заново</button>
        </div>
      </div>
    </div>
  </section>

  <section class="testimonials reveal" id="testimonials">
    <div class="container">
      <div class="eyebrow"><svg class="facet"><use href="#facet-icon"/></svg>Отзывы</div>
      <h2 class="section-title">Что говорят те, кто прошёл путь</h2>
      <div class="testimonials__grid">
        <div class="testimonial">«Отзыв клиента появится здесь»<span>— имя клиента</span></div>
        <div class="testimonial">«Отзыв клиента появится здесь»<span>— имя клиента</span></div>
        <div class="testimonial">«Отзыв клиента появится здесь»<span>— имя клиента</span></div>
      </div>
    </div>
  </section>

  <section class="final-cta reveal" id="contact">
    <svg class="facet" aria-hidden="true"><use href="#facet-icon"/></svg>
    <div class="container final-cta__inner">
      <h2>Готов(а) начать?</h2>
      <p>Запишись на консультацию или выбери формат, который откликнулся больше всего.</p>
      <a href="#top" class="btn btn--primary">Записаться</a>
    </div>
  </section>

</main>

<footer>
  Душа помнит · Мила Вайс — психолог, регрессолог, тренер системы Акаша
</footer>

<script>
  // Scroll reveal
  const revealEls = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('is-visible'); io.unobserve(e.target); } });
  },{threshold:.12});
  revealEls.forEach(el=>io.observe(el));

  // Quiz logic
  const quizData = [
    {
      q: "Что сейчас откликается больше?",
      options: [
        {text:"Не понимаю, что со мной происходит — нужна ясность", scores:{diag:2}},
        {text:"Накопилось напряжение, нужна поддержка и план", scores:{cons:2}},
        {text:"Чувствую, что корень — не в этой жизни", scores:{regr:2}},
        {text:"Готов(а) выйти на новый уровень осознанности", scores:{nast:2}},
        {text:"Ищу ответы на вопросы о пути и предназначении", scores:{akasha:2}}
      ]
    },
    {
      q: "Сколько времени готов(а) выделить на работу с собой?",
      options: [
        {text:"Разовая встреча, чтобы прояснить ситуацию", scores:{diag:1,cons:1}},
        {text:"Регулярные встречи, без глубокого погружения в прошлое", scores:{cons:1,nast:1}},
        {text:"Готов(а) к длительной и глубокой работе", scores:{regr:1,nast:1,akasha:1}}
      ]
    },
    {
      q: "Какой результат для тебя важнее?",
      options: [
        {text:"Понять причину происходящего", scores:{diag:1,regr:1}},
        {text:"Получить поддержку и конкретный план действий", scores:{cons:1,nast:1}},
        {text:"Прикоснуться к чему-то большему", scores:{akasha:1}}
      ]
    }
  ];

  const results = {
    diag:{title:"Диагностика (БДК)", text:"Тебе сейчас важнее точность: разобраться, что в действительности управляет твоим состоянием, прежде чем двигаться дальше."},
    cons:{title:"Консультация", text:"Тебе нужна живая опора здесь и сейчас — разговор, который проясняет ситуацию и даёт понятный план."},
    regr:{title:"Регрессии", text:"Похоже, ответ лежит глубже одной встречи — в корне, который сформировался раньше, чем ты думаешь."},
    nast:{title:"Наставничество", text:"Тебе откликается не разовая встреча, а сопровождение — путь, который проходишь не один(а)."},
    akasha:{title:"Система Акаша", text:"Тебя тянет не к ответам со стороны, а к тому, чтобы научиться находить их самостоятельно."}
  };

  let current = 0;
  const totals = {diag:0,cons:0,regr:0,nast:0,akasha:0};

  const stepEl = document.getElementById('quizStep');
  const qEl = document.getElementById('quizQuestion');
  const optsEl = document.getElementById('quizOptions');
  const formEl = document.getElementById('quizForm');
  const resultEl = document.getElementById('quizResult');
  const bars = [document.getElementById('bar1'),document.getElementById('bar2'),document.getElementById('bar3')];

  function renderQuestion(){
    const data = quizData[current];
    stepEl.textContent = `Вопрос ${current+1} из ${quizData.length}`;
    qEl.textContent = data.q;
    optsEl.innerHTML = '';
    data.options.forEach(opt=>{
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'quiz__option';
      b.textContent = opt.text;
      b.addEventListener('click', ()=>handleAnswer(opt.scores));
      optsEl.appendChild(b);
    });
    bars.forEach((bar,i)=>{ bar.style.width = i < current ? '100%' : '0%'; });
  }

  function handleAnswer(scores){
    Object.keys(scores).forEach(k=>{ totals[k] += scores[k]; });
    bars[current].style.width = '100%';
    current++;
    if(current < quizData.length){
      renderQuestion();
    } else {
      showResult();
    }
  }

  function showResult(){
    let best = 'cons', max = -1;
    Object.keys(totals).forEach(k=>{ if(totals[k] > max){ max = totals[k]; best = k; } });
    const r = results[best];
    document.getElementById('resultTitle').textContent = r.title;
    document.getElementById('resultText').textContent = r.text;
    document.getElementById('resultCta').textContent = `Записаться: ${r.title}`;
    formEl.classList.add('is-hidden');
    resultEl.classList.add('is-active');
  }

  document.getElementById('quizRestart').addEventListener('click', ()=>{
    current = 0;
    Object.keys(totals).forEach(k=> totals[k]=0);
    bars.forEach(bar=> bar.style.width='0%');
    resultEl.classList.remove('is-active');
    formEl.classList.remove('is-hidden');
    renderQuestion();
  });

  renderQuestion();
</script>

</body>
</html>
